# Contact form API (api/contact.js) – set these in Vercel Environment Variables or .env.local for local dev

# SMTP (e.g. Gmail: smtp.gmail.com, port 587; use an App Password if 2FA is on)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=

# Address that receives the contact form submissions
CONTACT_TO_EMAIL=
